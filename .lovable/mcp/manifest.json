      {
        "name": "my_bookings",
        "title": "حجوزاتي",
        "description": "يعرض حجوزات المستخدم الحالي في صالون هارون.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
